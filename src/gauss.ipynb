import numpy as np
import matplotlib.pyplot as plt
from sklearn.gaussian_process import GaussianProcessRegressor
from sklearn.gaussian_process.kernels import RBF, ConstantKernel as C

# 1. Generate synthetic data
X = np.linspace(0.1, 9.9, 20)[:, np.newaxis] # Input features (20 points from 0.1 to 9.9)
y = np.sin(X).ravel() # True function (sine wave)
# Add noise to targets
noise_std = 0.5
y_train = y + np.random.normal(loc=0.0, scale=noise_std, size=y.shape)

# 2. Define the kernel
# A common choice is the Radial Basis Function (RBF) kernel
kernel = C(1.0, (1e-3, 1e3)) * RBF(10.0, (1e-2, 1e2))

# 3. Initialize and fit the Gaussian Process Regressor
gaussian_process = GaussianProcessRegressor(
    kernel=kernel, 
    alpha=noise_std**2, # Account for noise variance
    n_restarts_optimizer=9
)
gaussian_process.fit(X, y_train)

# 4. Make predictions
# Define a range of test points
X_test = np.linspace(0, 10, 100)[:, np.newaxis]
# Predict mean and standard deviation
mean_prediction, std_prediction = gaussian_process.predict(X_test, return_std=True)

# 5. Plot the results (optional but highly recommended)
plt.figure(figsize=(10, 5))
plt.plot(X_test, y, linestyle="dotted", label=r"$f(x) = \sin(x)$")
plt.errorbar(X.ravel(), y_train, noise_std, linestyle="None", color="tab:blue", marker=".", markersize=10, label="Observations")
plt.plot(X_test, mean_prediction, label="Mean prediction")
# Fill the 95% confidence interval (mean +/- 2*std)
plt.fill_between(
    X_test.ravel(),
    mean_prediction - 1.96 * std_prediction,
    mean_prediction + 1.96 * std_prediction,
    alpha=0.3,
    label=r"95% confidence interval",
)
plt.xlabel("$x$")
plt.ylabel("$f(x)$")
plt.title("Gaussian Process Regression Example")
plt.legend()
plt.show()
